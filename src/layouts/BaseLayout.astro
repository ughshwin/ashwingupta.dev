---
import { ClientRouter } from "astro:transitions";
import { PageBackground } from "../app/components/PageBackground";
import "@fontsource/playfair-display/800.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/dm-sans/400.css";
import "@fontsource/dm-sans/500.css";
import "@fontsource/dm-sans/600.css";
import "@fontsource/dm-mono/400.css";
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  jsonLd?: object[];
}

const {
  title = "Ashwin Gupta - AI Systems Engineer",
  description = "Inference routing. Concurrency architecture. Physics-informed ML. An AI Systems Engineer who thinks in systems and in design - building what surrounds the model, not just the model itself. Bangalore.",
  canonical = "https://www.ashwingupta.dev/",
  image = "https://www.ashwingupta.dev/og-image.jpg",
  jsonLd = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ashwin Gupta" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1728" />
    <meta property="og:image:height" content="910" />
    <meta property="og:image:alt" content="Ashwin Gupta - AI Systems Engineer. Inference routing, concurrency architecture, physics-informed ML." />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@ashwingupta3012" />
    <meta name="twitter:creator" content="@ashwingupta3012" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <PageBackground client:load transition:persist="site-bg" />
    <slot />
  </body>
</html>
