    background: #060608;
    margin: 0;
    padding: 0;
  }

  .thinking-scroll {
    overflow-y: auto;
    height: 100vh;
    position: relative;
    z-index: 10;
  }

  .thinking-body {
    width: max(320px, 60vw);
    margin: 0 auto;
    padding: 5rem 0 8rem;
  }

  @media (min-width: 640px) {
    .thinking-body {
      padding: 7rem 0 8rem;
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    margin-bottom: 3.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: rgba(255, 255, 255, 0.9); }

  .th-header { margin-bottom: 2.5rem; }

  .th-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.54rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #22d3ee;
    margin-bottom: 1rem;
  }

  .th-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0.05em;
    color: #fafaf8;
    margin: 0 0 0.75rem;
  }

  .th-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    text-align: justify;
  }

  .th-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    margin: 2rem 0;
  }

  .th-section { margin-bottom: 3.5rem; }

  .th-section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: #fafaf8;
    margin: 0 0 1.2rem;
    letter-spacing: 0.05em;
  }

  .th-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.62);
    margin: 0 0 1rem;
    text-align: justify;
  }

  .th-body strong { color: #e8e0d0; font-weight: 600; }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #22d3ee;
    text-decoration: none;
    border: 1px solid rgba(34, 211, 238, 0.35);
    border-radius: 4px;
    padding: 8px 14px;
    transition: background 0.2s;
  }
  .cta-link:hover { background: rgba(34, 211, 238, 0.08); }

  .th-footer {
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.25);
    text-transform: uppercase;
  }
</style>
