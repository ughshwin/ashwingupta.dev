---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/index.css";

const canonical = "https://www.ashwingupta.dev/work/research-it";
const githubUrl = "https://github.com/ughshwin/research-it";
---

<BaseLayout
  title="Research-It — Fully Local RAG System | Ashwin Gupta"
  description="API-free academic document QA. LEANN/HNSW indexing, dense embeddings, Ollama inference. Reproducible indexes for air-gapped institutions."
  canonical={canonical}
>
  <div class="spatial-scene">
    <div class="thinking-scroll">
      <div class="thinking-body">

        <a href="/#projects" class="back-link">← Back to projects</a>

        <header class="th-header">
          <div class="th-badge">Shipped · Open Source</div>
          <h1 class="th-title">Research-It — Fully Local RAG System</h1>
          <p class="th-subtitle">Academic RAG without cloud inference. LEANN/HNSW indexing, dense embeddings, and Ollama-backed generation — designed for air-gapped institutions and privacy-constrained research.</p>
        </header>

        <div class="th-divider"></div>

        <section class="th-section">
          <h2 class="th-section-title">The Problem</h2>
          <p class="th-body">
            Academic RAG assumed cloud inference by default. Sensitive papers had no private processing path — all retrieval and generation required external API credentials. Researchers on CPU-only or low-VRAM hardware had no viable local inference option. Institutions with air-gap requirements were blocked by every existing tool.
          </p>
          <p class="th-body">
            Mixed source formats compounded the difficulty: PDFs, arXiv HTML pages, and paper directories each required separate handling logic that no single tool unified. The only path from ingestion to QA either exposed data externally or required manual preprocessing per source type.
          </p>
        </section>

        <section class="th-section">
          <h2 class="th-section-title">The System</h2>
          <p class="th-body">
            Fully local retrieval stack: <strong>LEANN/HNSW vector indexing</strong> with dense embeddings (facebook/contriever), Ollama-backed inference, and multi-source ingestion across PDFs, academic HTML, and paper directories. Quantized model support for CPU-only hardware. Smart chunking with configurable overlap, Top-K (3–4), and context windows (1,024–1,536 tokens).
          </p>
          <p class="th-body">
            PyMuPDF and BeautifulSoup handle varied PDF quality and HTML structure before indexing — not at query time. Retrieval quality problems are caught during ingestion, where they're fixable, rather than surfacing as silent errors in generated answers.
          </p>
        </section>

        <section class="th-section">
          <h2 class="th-section-title">Air-Gap Design</h2>
          <p class="th-body">
            Reproducible HNSW index artifacts are the key to air-gapped operation. Given the same corpus, the same index is produced — enabling institutions to build indexes in a connected environment and transfer them to isolated infrastructure without re-running ingestion. No external service is required at query time. API-free document QA across academic sources, running on sub-1GB quantized models.
          </p>
        </section>

        <div style="margin-bottom: 3.5rem;">
          <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="cta-link">
            ↗ View on GitHub
          </a>
        </div>

        <div class="th-footer">
          <span>© 2026 Ashwin Gupta · AI Engineer · Bangalore, India</span>
        </div>

      </div>
    </div>
  </div>
</BaseLayout>

<style>
  body {
    background: #060608;
    margin: 0;
    padding: 0;
  }

  .thinking-scroll {
    overflow-y: auto;
    height: 100vh;
    position: relative;
    z-index: 10;
  }

  .thinking-body {
    width: max(320px, 60vw);
    margin: 0 auto;
    padding: 5rem 0 8rem;
  }

  @media (min-width: 640px) {
    .thinking-body {
      padding: 7rem 0 8rem;
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    margin-bottom: 3.5rem;
    transition: color 0.2s;
  }
  .back-link:hover { color: rgba(255, 255, 255, 0.9); }

  .th-header { margin-bottom: 2.5rem; }

  .th-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.54rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #22d3ee;
    margin-bottom: 1rem;
  }

  .th-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: 0.05em;
    color: #fafaf8;
    margin: 0 0 0.75rem;
  }

  .th-subtitle {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
    text-align: justify;
  }

  .th-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.07);
    margin: 2rem 0;
  }

  .th-section { margin-bottom: 3.5rem; }

  .th-section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: #fafaf8;
    margin: 0 0 1.2rem;
    letter-spacing: 0.05em;
  }

  .th-body {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.62);
    margin: 0 0 1rem;
    text-align: justify;
  }

  .th-body strong { color: #e8e0d0; font-weight: 600; }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #22d3ee;
    text-decoration: none;
    border: 1px solid rgba(34, 211, 238, 0.35);
    border-radius: 4px;
    padding: 8px 14px;
    transition: background 0.2s;
  }
  .cta-link:hover { background: rgba(34, 211, 238, 0.08); }

  .th-footer {
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.07);
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.25);
    text-transform: uppercase;
  }
</style>
