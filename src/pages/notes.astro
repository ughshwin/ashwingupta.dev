---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/index.css";

const canonical = "https://www.ashwingupta.dev/notes";
---

<BaseLayout
  title="Notes | Ashwin Gupta"
  description="Writing on inference routing, scientific ML, production AI systems, and anything worth saying."
  canonical={canonical}
>
  <div class="spatial-scene">
    <div class="hologram-interface" style="overflow-y: auto; height: 100vh; position: relative; z-index: 10;">
      <div style="min-height: 100vh; padding: clamp(6rem, 12vw, 10rem) clamp(1.5rem, 6vw, 6vw) 6rem; max-width: 680px; margin: 0 auto;">

        <!-- Back link -->
        <a
          href="/"
          style="display: inline-flex; align-items: center; gap: 8px; font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35); text-decoration: none; margin-bottom: 4rem; transition: color 0.2s;"
          onmouseover="this.style.color='rgba(255,255,255,0.9)'"
          onmouseout="this.style.color='rgba(255,255,255,0.35)'"
        >
          ← Back
        </a>

        <!-- Section label -->
        <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;">
          <span style="font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.2em; color: rgba(255,255,255,0.4); text-transform: uppercase;">
            Notes
          </span>
          <div style="flex: 1; height: 1px; background: rgba(255,255,255,0.07);"></div>
        </div>

        <!-- Header -->
        <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 800; line-height: 1.05; letter-spacing: -0.03em; color: #fafaf8; margin: 0 0 1.5rem;">
          Work worth saying.
        </h1>

        <!-- Empty state -->
        <div style="padding: 3rem 0; border-top: 1px solid rgba(255,255,255,0.07); border-bottom: 1px solid rgba(255,255,255,0.07);">
          <p style="font-family: 'DM Mono', monospace; font-size: 0.72rem; letter-spacing: 0.08em; color: rgba(255,255,255,0.3); margin: 0;">
            Nothing published yet. When something's worth saying, it'll be here.
          </p>
        </div>

        <!-- What's coming note -->
        <div style="margin-top: 2rem;">
          <p style="font-family: 'DM Sans', sans-serif; font-size: 0.83rem; line-height: 1.7; color: rgba(255,255,255,0.35); margin: 0; max-width: 480px;">
            Topics: inference routing, why most RAG systems miss the point, PINNs for people who actually build things,
            what production AI looks like from the inside, anything with a defensible opinion behind it.
          </p>
        </div>

        <!-- Footer -->
        <div style="margin-top: 8rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.07);">
          <span style="font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.25); text-transform: uppercase;">
            © 2026 Ashwin Gupta · AI Engineer · Bangalore, India
          </span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  body {
    background: #060608;
    margin: 0;
    padding: 0;
  }
  .environment-placeholder {
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at 30% 20%, rgba(30, 30, 50, 0.4) 0%, #060608 70%);
    z-index: 0;
  }
  .hologram-interface {
    position: relative;
  }
</style>
